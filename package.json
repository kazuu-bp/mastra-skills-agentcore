{
    "name": "mastra-agentcore-cdk",
    "version": "0.1.0",
    "bin": {
        "mastra-agentcore-cdk": "bin/app.js"
    },
    "scripts": {
        "build": "tsc",
        "watch": "tsc -w",
        "login": "aws sts get-caller-identity > /dev/null 2>&1 || aws login",
        "cdk": "cdk",
        "cdk:synth": "cdk synth",
        "cdk:deploy": "npm run login && cdk deploy --require-approval never",
        "cdk:destroy": "npm run login && cdk destroy",
        "test:invoke": "npx tsx test-invoke.mts"
    },
    "devDependencies": {
        "@types/node": "^22.7.9",
        "aws-cdk": "^2.222.0",
        "ts-node": "^10.9.2",
        "typescript": "~5.6.3"
    },
    "dependencies": {
        "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.221.1-alpha.0",
        "@aws-sdk/client-bedrock-agentcore": "^3.1000.0",
        "@cdklabs/deploy-time-build": "^0.0.6",
        "aws-cdk-lib": "^2.222.0",
        "constructs": "^10.4.2",
        "pptxgenjs": "^4.0.1"
    }
}
